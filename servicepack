# 11. rafaelia_dispatch.c — Dispatch runtime
# =============================================================================
cat > "$REPO/rafaelia/src/main/cpp/rafaelia_dispatch.c" << 'EOF'
/*
 * rafaelia_dispatch.c — Dispatch runtime para VECTRA_OS
 *
 * Sem malloc. Sem libc. Sem printf.
 * Detecta AArch64 → ARM32 → C fallback em compile-time.
 * Runtime NEON check via sys/auxv.h (disponível no Android NDK).
 */

#include "rafaelia_dispatch.h"

#if defined(__aarch64__)
extern uint32_t vectra_aarch64_run_n(
    void*, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t);
extern uint32_t vectra_aarch64_step_once(
    void*, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t);
#elif defined(__arm__)
extern uint32_t vectra_arm32_run_n(
    void*, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t, uint32_t);
#endif

extern int      vectra_fallback_init(uint32_t);
extern uint32_t vectra_fallback_step(void);
extern void     vectra_fallback_step_n(uint32_t);
extern void     vectra_fallback_get_state(VectraState *);

int rafaelia_detect_backend(void) {
#if defined(__aarch64__)
    return RAFAELIA_BACKEND_AARCH64;
#elif defined(__arm__)
    return RAFAELIA_BACKEND_ARM32;
#else
    return RAFAELIA_BACKEND_C_FALLBACK;
#endif
}

uint32_t rafaelia_run(void *state_buf, uint32_t *regs, uint32_t n_steps) {
    if (!state_buf || !regs || n_steps == 0) return FLAG_GI_FAIL;

    uint32_t C         = regs[0];
    uint32_t H         = regs[1];
    uint32_t phase     = regs[2];
    uint32_t attractor = regs[3];
    uint32_t delta     = regs[4];
    uint32_t fnv_hash  = regs[5];
    uint32_t flags     = regs[6];

#if defined(__aarch64__)
    return vectra_aarch64_run_n(
        state_buf, C, H, phase, attractor, delta, fnv_hash, flags, n_steps);
#elif defined(__arm__)
    return vectra_arm32_run_n(
        state_buf, C, H, phase, attractor, delta, fnv_hash, flags, n_steps);
#else
    VectraState tmp;
    tmp.base      = state_buf;
    tmp.C         = C;
    tmp.H         = H;
    tmp.phase     = phase;
    tmp.attractor = attractor;
    tmp.delta     = delta;
    tmp.fnv_hash  = fnv_hash;
    tmp.flags     = flags;

    uint32_t blocks = n_steps >> 3;
    uint32_t remain = n_steps & 7U;
    while (blocks--) {
        COLLAPSE_STEP(&tmp); COLLAPSE_STEP(&tmp);
        COLLAPSE_STEP(&tmp); COLLAPSE_STEP(&tmp);
        COLLAPSE_STEP(&tmp); COLLAPSE_STEP(&tmp);
        COLLAPSE_STEP(&tmp); COLLAPSE_STEP(&tmp);
    }
    switch (remain) {
        case 7: COLLAPSE_STEP(&tmp);
        case 6: COLLAPSE_STEP(&tmp);
        case 5: COLLAPSE_STEP(&tmp);
        case 4: COLLAPSE_STEP(&tmp);
        case 3: COLLAPSE_STEP(&tmp);
        case 2: COLLAPSE_STEP(&tmp);
        case 1: COLLAPSE_STEP(&tmp);
        default: break;
    }
    MERKLE_FLUSH(&tmp);

    regs[0] = tmp.C;
    regs[1] = tmp.H;
    regs[2] = tmp.phase;
    regs[3] = tmp.attractor;
    regs[4] = tmp.delta;
    regs[5] = tmp.fnv_hash;
    regs[6] = tmp.flags;
    return tmp.flags;
#endif
