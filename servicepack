/*
 * gcd_invariant.h — Verificação GCD inline para R=42
 *
 * CONTRATO VECTRA_OS:
 *   gcd(Δr, R) == 1 → continuar
 *   gcd(Δr, R) != 1 → HALT + setar bit 7 (geometric_invariant_fail)
 *
 * Implementação: bitmask pré-computado para R=42.
 * Sem libc, sem malloc, sem divisão de propósito geral.
 *
 * Valores válidos de Δr mod 42 (coprimos com 42):
 *   1,5,11,13,17,19,23,25,29,31,37,41
 *
 * Máscara de 64 bits: bit i = 1 se gcd(i,42)==1
 *   Bits baixos (0-31): 0xA2AA2822
 *   Bits altos (32-63): 0x00000220
 *   Máscara completa:   0x00000220A2AA2822ULL
 */
#ifndef VECTRA_GCD_INVARIANT_H
#define VECTRA_GCD_INVARIANT_H

#include <stdint.h>
#include "torus_cells.h"

/*
 * Máscara para R=42:
 * posição  valor  coprimo?
 *  0       42     N
 *  1        1     Y → bit 1
 *  5        1     Y → bit 5
 * 11        1     Y → bit 11
 * 13        1     Y → bit 13
 * 17        1     Y → bit 17
 * 19        1     Y → bit 19
 * 23        1     Y → bit 23
 * 25        1     Y → bit 25
 * 29        1     Y → bit 29
 * 31        1     Y → bit 31
 * 37        1     Y → bit 37
 * 41        1     Y → bit 41
 */
#define GCD_COPRIME_MASK  0x00000220A2AA2822ULL

/* Flags bit 7 = geometric_invariant_fail */
#define FLAG_GI_FAIL      (1U << 7)

/*
 * GCD_CHECK(delta, flags_ref)
 * Avalia gcd(delta % R, R). Se != 1, seta bit 7 em flags_ref.
 * Sem chamadas de função. Sem loops. Expande inline.
 *
 * NOTA: delta é uint32_t; flags_ref é uint32_t* (ponteiro para x7 simulado).
 */
#define GCD_CHECK(delta, flags_ref)                                    \
    do {                                                               \
        uint32_t _d = (uint32_t)(delta) % TORUS_R;                   \
        uint64_t _mask = GCD_COPRIME_MASK;                            \
        uint32_t _valid = (uint32_t)((_mask >> _d) & 1U);            \
        /* Se inválido: OR bit 7 — csel equivalente em C */           \
        *(flags_ref) = (*(flags_ref)) | (FLAG_GI_FAIL & (uint32_t)((_valid - 1U))); \
    } while (0)

/*
 * GCD_IS_VALID(delta)
 * Retorna 1 se gcd(delta, 42)==1, 0 caso contrário.
 * Inline puro, sem chamada de função.
 */
#define GCD_IS_VALID(delta)                                            \
    ((uint32_t)((GCD_COPRIME_MASK >> ((uint32_t)(delta) % TORUS_R)) & 1U))

#endif /* VECTRA_GCD_INVARIANT_H */
EOF

