/*
 * torus_cells.h — Layout de memória estática do vetor de estado VECTRA_OS
 *
 * CONTRATO: sem malloc, sem libc, sem frames de pilha.
 * Toda memória é estática ou pré-alocada pelo chamador JNI.
 *
 * Layout do vetor de estado (base = x0):
 *
 *  Offset  Tamanho  Campo
 *  0x000   336 B    attractor_cells[42]  (42 × uint64_t)
 *  0x150   168 B    coherence_hist[42]   (42 × uint32_t, Q16.16)
 *  0x1F8   168 B    entropy_hist[42]     (42 × uint32_t, Q16.16)
 *  0x2A0   340 B    merkle_tree[85]      (árvore binária para 42 folhas)
 *  0x3F4     4 B    crc32_mirror         (uint32_t)
 *  0x3F8     4 B    phase_stamp          (uint32_t)
 *  0x3FC     4 B    flags_mirror         (espelho de x7, uint32_t)
 *  ------
 *  Total: 0x400 = 1024 bytes — DEVE estar alinhado a 8 bytes
 */
#ifndef VECTRA_TORUS_CELLS_H
#define VECTRA_TORUS_CELLS_H

#include <stdint.h>

/* Tamanho total do estado — sem malloc, alocado estaticamente */
#define TORUS_STATE_SIZE        1024U

/* Offsets absolutos a partir do ponteiro base (x0) */
#define SV_ATTRACTOR_BASE       0x000U   /* uint64_t[42] */
#define SV_COHERENCE_HIST       0x150U   /* uint32_t[42] Q16.16 */
#define SV_ENTROPY_HIST         0x1F8U   /* uint32_t[42] Q16.16 */
#define SV_MERKLE_TREE          0x2A0U   /* uint32_t[85] */
#define SV_CRC32_MIRROR         0x3F4U   /* uint32_t */
#define SV_PHASE_STAMP          0x3F8U   /* uint32_t */
#define SV_FLAGS_MIRROR         0x3FCU   /* uint32_t = espelho de x7 */

/* Número de atratores — R no contrato GCD */
#define TORUS_R                 42U

/* Atrator VOID — destino de erro, nunca válido em fluxo normal */
#define ATTRACTOR_VOID          22U

/* Constante Q16.16 para "um" = 0x00010000 */
#define Q16_ONE                 0x00010000U

/* Macros de acesso sem função (sem overhead de call) */
#define TORUS_ATTRACTOR(base, idx) \
    (((volatile uint64_t *)((uint8_t *)(base) + SV_ATTRACTOR_BASE))[(idx)])

#define TORUS_COHERENCE(base, idx) \
    (((volatile uint32_t *)((uint8_t *)(base) + SV_COHERENCE_HIST))[(idx)])

#define TORUS_ENTROPY(base, idx) \
    (((volatile uint32_t *)((uint8_t *)(base) + SV_ENTROPY_HIST))[(idx)])

#define TORUS_MERKLE(base, idx) \
    (((volatile uint32_t *)((uint8_t *)(base) + SV_MERKLE_TREE))[(idx)])

#define TORUS_FLAGS_MIRROR(base) \
    (*((volatile uint32_t *)((uint8_t *)(base) + SV_FLAGS_MIRROR)))

#define TORUS_PHASE_STAMP(base) \
    (*((volatile uint32_t *)((uint8_t *)(base) + SV_PHASE_STAMP)))

#define TORUS_CRC32(base) \
    (*((volatile uint32_t *)((uint8_t *)(base) + SV_CRC32_MIRROR)))

/* Verificação de alinhamento em tempo de compilação */
_Static_assert(TORUS_STATE_SIZE == 1024, "torus state deve ser 1024 bytes");
_Static_assert((SV_ATTRACTOR_BASE & 7) == 0, "attractor_cells deve estar alinhado a 8 bytes");
_Static_assert((SV_MERKLE_TREE & 3) == 0, "merkle_tree deve estar alinhado a 4 bytes");

#endif /* VECTRA_TORUS_CELLS_H */
EOF

