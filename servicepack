/*
 * vectra_os.h — Contrato mestre VECTRA_OS
 *
 * Zero OS. Zero libc. Zero stack frames.
 * Cada byte é uma decisão de registrador.
 * Cada desvio é um teste de invariante geométrica.
 *
 * MAPA DE REGISTROS (contrato fixo AArch64 / ARM32)
 *   x0  = ponteiro base do vetor de estado   (NUNCA liberado no ciclo)
 *   x1  = coerência C   (Q16.16 ponto fixo)
 *   x2  = entropia H    (Q16.16 ponto fixo)
 *   x3  = contador de fase mod 42
 *   x4  = índice do atrator (0..41)
 *   x5  = delta / scratch
 *   x6  = acumulador hash FNV (em execução)
 *   x7  = registrador de flags (compactado em bits)
 *
 * REGISTROS AUXILIARES (scratch de macro, não exportados)
 *   x8  = FNV_PRIME pré-carregado (0x01000193) — fixo durante COLLAPSE
 *   x9..x15 = scratch de macro (sem semântica persistente)
 *
 * FLAGS (x7, bit-packed)
 *   bit 0 = LOCK ativo
 *   bit 1 = FLOW ativo
 *   bit 2 = VOID acionado
 *   bit 3 = trickstopathcutter ativo
 *   bit 4 = viscosity_negative
 *   bit 5 = attractor_jump_pending
 *   bit 6 = merkle_dirty
 *   bit 7 = geometric_invariant_fail
 *
 * INVARIANTE (sem exceção):
 *   gcd(Δr, R) == 1 → continuar
 *   gcd(Δr, R) != 1 → HALT + setar bit 7
 */
#ifndef VECTRA_OS_H
#define VECTRA_OS_H

#include <stdint.h>
#include "torus_cells.h"
#include "gcd_invariant.h"
#include "fnv_hash.h"
#include "merkle_crc.h"

/* =========================================================================
 * Flags — bit positions em x7
 * ======================================================================= */
#define FLAG_LOCK           (1U << 0)
#define FLAG_FLOW           (1U << 1)
#define FLAG_VOID           (1U << 2)
#define FLAG_TRICKSTOP      (1U << 3)
#define FLAG_VISC_NEG       (1U << 4)
#define FLAG_JUMP_PENDING   (1U << 5)
#define FLAG_MERKLE_DIRTY   (1U << 6)
#define FLAG_GI_FAIL        (1U << 7)

/* =========================================================================
 * Vetor de estado em C (espelho dos registros x0..x7)
 * Usado pelo C fallback e pelo JNI bridge para re-materialização.
 * Alinhado a 64 bytes para cache-line eviction zero.
 * ======================================================================= */
typedef struct __attribute__((aligned(64))) VectraState {
    void     *base;      /* x0: ponteiro para TORUS_STATE_SIZE bytes */
    uint32_t  C;         /* x1: coerência Q16.16 */
    uint32_t  H;         /* x2: entropia Q16.16  */
    uint32_t  phase;     /* x3: contador de fase mod 42 */
    uint32_t  attractor; /* x4: índice do atrator (0..41) */
    uint32_t  delta;     /* x5: delta Δr */
    uint32_t  fnv_hash;  /* x6: acumulador FNV */
    uint32_t  flags;     /* x7: flags compactadas */
} VectraState;

/* =========================================================================
 * VOID_CHECK(state)
 * Se FLAG_VOID setado → redireciona atrator para VOID (22)
 * Equivalente C de: csel x4, #22, x4, ne
 * ======================================================================= */
#define VOID_CHECK(state)                                              \
    do {                                                               \
        uint32_t _void_mask = (uint32_t)(-((int32_t)(               \
            ((state)->flags & FLAG_VOID) != 0U)));                    \
        (state)->attractor = ((state)->attractor & ~_void_mask)       \
                           | (ATTRACTOR_VOID & _void_mask);           \
    } while (0)

/* =========================================================================
 * GI_CHECK(state)
 * Verifica invariante GCD. Se falhar: seta FLAG_GI_FAIL.
 * HALT semântico: após bit 7 setado, COLLAPSE_STEP não avança.
 * ======================================================================= */
#define GI_CHECK(state) \
    GCD_CHECK((state)->delta, &(state)->flags)

/* =========================================================================
 * COHERENCE_UPDATE(state)
 * Atualiza C (Q16.16): C = C - (C >> 4) + (H >> 8)
 * Dinâmica de coerência: decai por 1/16 e absorve H/256 por ciclo.
 * Sem ponto flutuante. Operações de shift em ponto fixo Q16.16.
 * ======================================================================= */
#define COHERENCE_UPDATE(state)                                        \
    do {                                                               \
        uint32_t _decay  = (state)->C >> 4;                           \
        uint32_t _inject = (state)->H >> 8;                           \
        (state)->C = (state)->C - _decay + _inject;                   \
    } while (0)

/* =========================================================================
 * ENTROPY_UPDATE(state)
 * Atualiza H (Q16.16): H = H + (delta << 4) - (H >> 6)
 * Sem ponto flutuante. Delta em Q16.16 significa shift implícito de 16.
 * ======================================================================= */
#define ENTROPY_UPDATE(state)                                          \
    do {                                                               \
        uint32_t _inject = (state)->delta << 4;                       \
        uint32_t _damp   = (state)->H >> 6;                           \
        (state)->H = (state)->H + _inject - _damp;                    \
    } while (0)

/* =========================================================================
 * PHASE_ADVANCE(state)
 * Incrementa fase mod 42.
 * Equivalente C de: add+cmp+csel (3 instruções ARM)
 * ======================================================================= */
#define PHASE_ADVANCE(state)                                           \
    do {                                                               \
        uint32_t _next = (state)->phase + 1U;                         \
        /* csel equivalente: sem branch */                             \
        uint32_t _wrap = (uint32_t)(-((int32_t)(_next >= TORUS_R))); \
        (state)->phase = _next & ~_wrap;                              \
    } while (0)

/* =========================================================================
 * ATTRACTOR_ADVANCE(state)
 * Avança atrator: (attractor + delta) mod 42
 * Limpa FLAG_JUMP_PENDING após o salto.
 * ======================================================================= */
#define ATTRACTOR_ADVANCE(state)                                       \
    do {                                                               \
        uint32_t _a = ((state)->attractor + (state)->delta) % TORUS_R; \
        (state)->attractor = _a;                                       \
        (state)->flags &= ~FLAG_JUMP_PENDING;                         \
    } while (0)

/* =========================================================================
 * HASH_STEP(state)
 * FNV-1a com o byte baixo de coerência atual.
 * ======================================================================= */
#define HASH_STEP(state) \
    FNV_UPDATE(&(state)->fnv_hash, (uint8_t)((state)->C & 0xFFU))

/* =========================================================================
 * TORUS_WRITE(state)
 * Escreve attractor_cells[phase] = current attractor index.
 * Marca merkle_dirty.
 * ======================================================================= */
#define TORUS_WRITE(state)                                             \
    do {                                                               \
        TORUS_ATTRACTOR((state)->base, (state)->phase) =              \
            (uint64_t)(state)->attractor;                             \
        TORUS_COHERENCE((state)->base, (state)->phase) = (state)->C;  \
        TORUS_ENTROPY((state)->base,   (state)->phase) = (state)->H;  \
        (state)->flags |= FLAG_MERKLE_DIRTY;                          \
    } while (0)

/* =========================================================================
 * MERKLE_FLUSH(state)
 * Faz commit Merkle se merkle_dirty setado.
 * Sem branch: usa máscara csel-equivalente.
 * ======================================================================= */
#define MERKLE_FLUSH(state)                                            \
    do {                                                               \
        if ((state)->flags & FLAG_MERKLE_DIRTY) {                     \
            MERKLE_COMMIT((state)->base, (state)->phase,              \
                          (state)->attractor, &(state)->flags);        \
        }                                                              \
    } while (0)

/* =========================================================================
 * COLLAPSE_STEP(state)
 * Uma expansão de macro = um ciclo completo VECTRA.
 * NÃO É uma função. Expansão inline pura.
 *
 * Orçamento de ciclos (Cortex-A53 estimado):
 *   VOID_CHECK      : ~2 ciclos
 *   GI_CHECK        : ~6 ciclos
 *   COHERENCE_UPDATE: ~3 ciclos
 *   ENTROPY_UPDATE  : ~3 ciclos
 *   PHASE_ADVANCE   : ~3 ciclos
 *   ATTRACTOR_ADVANCE: ~4 ciclos (inclui udiv)
 *   HASH_STEP       : ~4-5 ciclos
 *   TORUS_WRITE     : ~6 ciclos (3 stores)
 *   TOTAL estimado  : ~31-32 ciclos (dentro do budget ≤42)
 *
 * "Petros" (estado já pedra): se FLAG_GI_FAIL setado, nenhuma atualização
 * de estado ocorre — o ciclo é um NOP geométrico.
 * ======================================================================= */
#define COLLAPSE_STEP(state)                                           \
    do {                                                               \
        /* [1] VOID_check: 1 ciclo lógico */                          \
        VOID_CHECK(state);                                             \
        /* [2] GCD invariant: HALT semântico se gcd fail */           \
        GI_CHECK(state);                                               \
        /* [3] Petros: se GI_FAIL setado, não avança */               \
        if (!((state)->flags & FLAG_GI_FAIL)) {                       \
            /* [4] Dinâmica de coerência */                            \
            COHERENCE_UPDATE(state);                                   \
            /* [5] Dinâmica de entropia */                             \
            ENTROPY_UPDATE(state);                                     \
            /* [6] Avança fase mod 42 */                              \
            PHASE_ADVANCE(state);                                      \
            /* [7] Salta atrator se pendente ou sempre avança */       \
            ATTRACTOR_ADVANCE(state);                                  \
            /* [8] Atualiza hash FNV com coerência atual */           \
            HASH_STEP(state);                                          \
            /* [9] Escreve em torus_cells, marca merkle_dirty */       \
            TORUS_WRITE(state);                                        \
        }                                                              \
    } while (0)

/* =========================================================================
 * VECTRA_INIT(state, base_ptr, delta_val)
 * Inicializa vetor de estado antes do primeiro COLLAPSE_STEP.
 * base_ptr deve apontar para TORUS_STATE_SIZE bytes alinhados a 8 bytes.
 * ======================================================================= */
#define VECTRA_INIT(state, base_ptr, delta_val)                        \
    do {                                                               \
        (state)->base      = (base_ptr);                              \
        (state)->C         = Q16_ONE;      /* coerência inicial = 1.0 */ \
        (state)->H         = Q16_ONE >> 2; /* entropia inicial = 0.25 */ \
        (state)->phase     = 0U;                                       \
        (state)->attractor = 0U;                                       \
        (state)->delta     = (uint32_t)(delta_val);                   \
        FNV_INIT(&(state)->fnv_hash);                                  \
        (state)->flags     = FLAG_FLOW;   /* inicia em FLOW */         \
        /* Valida delta imediatamente */                               \
        GI_CHECK(state);                                               \
    } while (0)

#endif /* VECTRA_OS_H */
EOF

# =============================================================================
# 6. vectra_fallback.c — Implementação C pura, sem libc, sem malloc
# =============================================================================
cat > "$REPO/rmr/src/main/cpp/vectra_fallback.c" << 'EOF'
/*
 * vectra_fallback.c — Implementação C bare-metal do contrato VECTRA_OS
 *
 * SEM libc. SEM malloc. SEM printf. SEM errno. SEM stack frames profundos.
 * Compilado com: -ffreestanding -fno-builtin -fno-stack-protector
 *                -fomit-frame-pointer -O2
 *
 * Esta implementação é o fallback quando AArch64/ARM32 ASM não está disponível.
 * Produz código equivalente via macros do vectra_os.h.
 */

#include "vectra_os.h"

/* Buffer estático de estado — sem malloc */
static uint8_t _static_torus_buffer[TORUS_STATE_SIZE]
    __attribute__((aligned(64), section(".bss")));

static VectraState _static_vectra_state __attribute__((aligned(64)));

/* =========================================================================
 * vectra_fallback_init
 * Inicializa o estado com delta_val e o buffer estático.
 * Retorna 0 se OK, -1 se GCD invariant falhou na inicialização.
 * Sem exceções. Sem malloc.
 * ======================================================================= */
int vectra_fallback_init(uint32_t delta_val) {
    VECTRA_INIT(&_static_vectra_state, _static_torus_buffer, delta_val);
    /* Se delta inválido, GI_FAIL já estará setado */
    return (_static_vectra_state.flags & FLAG_GI_FAIL) ? -1 : 0;
}

/* =========================================================================
 * vectra_fallback_step
 * Executa um COLLAPSE_STEP. Sem função de callback. Sem exceções.
 * Retorna flags atuais de x7.
 * ======================================================================= */
uint32_t vectra_fallback_step(void) {
    COLLAPSE_STEP(&_static_vectra_state);
    return _static_vectra_state.flags;
}

/* =========================================================================
 * vectra_fallback_step_n
 * Executa N passos COLLAPSE sem loop de alto nível (desenrolado × 8).
 * n DEVE ser gcd-provado terminante pelo chamador.
 * Para terminação garantida: n deve ser múltiplo de 1 (sempre termina).
 * ======================================================================= */
void vectra_fallback_step_n(uint32_t n) {
    /* Sem loop indefinido. Cada 8 passos = 1 unidade de orçamento. */
    uint32_t blocks  = n >> 3;        /* n / 8 */
    uint32_t remain  = n & 7U;        /* n % 8 */

    /* Bloco de 8 — termina em exatamente 8 passos */
    while (blocks--) {
        COLLAPSE_STEP(&_static_vectra_state);
        COLLAPSE_STEP(&_static_vectra_state);
        COLLAPSE_STEP(&_static_vectra_state);
        COLLAPSE_STEP(&_static_vectra_state);
        COLLAPSE_STEP(&_static_vectra_state);
        COLLAPSE_STEP(&_static_vectra_state);
        COLLAPSE_STEP(&_static_vectra_state);
        COLLAPSE_STEP(&_static_vectra_state);
    }
    /* Remainder 0..7 — unrolled, sem branch em loop */
    switch (remain) {
        case 7: COLLAPSE_STEP(&_static_vectra_state); /* fall through */
        case 6: COLLAPSE_STEP(&_static_vectra_state);
        case 5: COLLAPSE_STEP(&_static_vectra_state);
        case 4: COLLAPSE_STEP(&_static_vectra_state);
        case 3: COLLAPSE_STEP(&_static_vectra_state);
        case 2: COLLAPSE_STEP(&_static_vectra_state);
        case 1: COLLAPSE_STEP(&_static_vectra_state);
        default: break;
    }
}

/* =========================================================================
 * vectra_fallback_flush_merkle
 * Força flush Merkle se dirty. Deve ser chamado após ciclos batch.
 * ======================================================================= */
void vectra_fallback_flush_merkle(void) {
    MERKLE_FLUSH(&_static_vectra_state);
}

/* =========================================================================
 * vectra_fallback_get_state
 * Copia o estado atual para destino (para leitura pelo JNI).
 * Sem malloc, sem heap.
 * ======================================================================= */
void vectra_fallback_get_state(VectraState *dst) {
    if (!dst) return;
    *dst = _static_vectra_state;
}

/* =========================================================================
 * vectra_fallback_get_root_hash
 * Retorna o hash Merkle raiz atual (nó 84 da árvore binária).
 * ======================================================================= */
uint32_t vectra_fallback_get_root_hash(void) {
    return TORUS_MERKLE(_static_torus_buffer, 84);
}
EOF

# =============================================================================
# 7. vectra_aarch64.S — Implementação AArch64 pura (macros de montador)
# =============================================================================
cat > "$REPO/rmr/src/main/cpp/vectra_aarch64.S" << 'EOF'
/*
 * vectra_aarch64.S — Implementação AArch64 do contrato VECTRA_OS
 *
 * ZERO OS. ZERO libc. ZERO stack frames.
 * Cada instrução é uma decisão de registrador.
 *
 * MAPA DE REGISTROS (contrato fixo):
 *   x0  = state_vector base ptr
 *   x1  = coerência C   (Q16.16, usa w1 para operações 32-bit)
 *   x2  = entropia H    (Q16.16, usa w2)
 *   x3  = fase mod 42   (usa w3)
 *   x4  = atrator 0..41 (usa w4)
 *   x5  = delta Δr      (usa w5)
 *   x6  = hash FNV      (usa w6)
 *   x7  = flags         (usa w7)
 *
 * REGISTROS AUXILIARES (scratch, dentro das macros):
 *   x8  = FNV_PRIME pré-carregado (0x01000193) — fixo no ciclo
 *   x9  = scratch 1
 *   x10 = scratch 2
 *   x11 = scratch 3
 *   x12 = endereço de escrita torus
 *   x13 = scratch 4
 *   x14 = scratch 5
 *   x15 = scratch 6
 */

    .arch armv8-a
    .text

/* =========================================================================
 * Constantes globais — segmento de dados somente leitura
 * ======================================================================= */
    .section .rodata
    .align 3
.Ltorus_r:
    .quad   42
.Lattractor_void:
    .quad   22
.Lfnv_prime:
    .word   0x01000193
.Lfnv_offset:
    .word   0x811C9DC5
/* Máscara GCD coprima com 42 (64 bits) */
.Lgcd_mask_lo:
    .word   0xA2AA2822
.Lgcd_mask_hi:
    .word   0x00000220
.Lq16_one:
    .word   0x00010000

/* =========================================================================
 * Macro: VECTRA_VOID_CHECK
 * Redireciona atrator para VOID (#22) se bit 2 de x7 estiver setado.
 * Custo: 3 instruções, ~3 ciclos (sem mispredict: csel inline)
 * ======================================================================= */
    .macro VECTRA_VOID_CHECK
    mov     w9,  #22                // ATTRACTOR_VOID
    tst     w7,  #(1 << 2)         // test FLAG_VOID (bit 2)
    csel    w4,  w9, w4, ne        // if VOID: attractor = 22
    .endm

/* =========================================================================
 * Macro: VECTRA_GI_CHECK
 * Verifica gcd(Δr, 42) == 1 via bitmask lookup.
 * Se falhar: seta bit 7 (geometric_invariant_fail).
 * Custo: ~8 ciclos (3 mov/movk + udiv + msub + lsr + tst + orr + csel)
 * ======================================================================= */
    .macro VECTRA_GI_CHECK
    /* Carrega máscara coprima de 64 bits */
    movz    x9,  #0x2822
    movk    x9,  #0xA2AA, lsl #16
    movk    x9,  #0x0220, lsl #32
    /* delta mod 42 */
    mov     w10, #42
    udiv    w11, w5, w10            // w11 = delta / 42
    msub    w10, w11, w10, w5      // w10 = delta - (w11 * 42) = delta % 42
    /* Testa bit na máscara */
    lsr     x9,  x9,  x10
    tst     x9,  #1                 // ZF=1 se NÃO coprimo
    /* Se ZF: seta FLAG_GI_FAIL (bit 7) — csel sem branch */
    orr     w11, w7, #(1 << 7)
    csel    w7,  w11, w7, eq       // se não coprimo: flags |= bit 7
    .endm

/* =========================================================================
 * Macro: VECTRA_COHERENCE_UPDATE
 * C = C - (C >> 4) + (H >> 8)
 * Custo: ~3 ciclos (lsr + sub + lsr + add = 4 instruções, pipeline 3)
 * ======================================================================= */
    .macro VECTRA_COHERENCE_UPDATE
    lsr     w9,  w1, #4            // decay = C >> 4
    sub     w1,  w1, w9            // C = C - decay
    lsr     w9,  w2, #8            // inject = H >> 8
    add     w1,  w1, w9            // C = C + inject
    .endm

/* =========================================================================
 * Macro: VECTRA_ENTROPY_UPDATE
 * H = H + (delta << 4) - (H >> 6)
 * Custo: ~3 ciclos
 * ======================================================================= */
    .macro VECTRA_ENTROPY_UPDATE
    lsl     w9,  w5, #4            // inject = delta << 4
    add     w2,  w2, w9            // H = H + inject
    lsr     w9,  w2, #6            // damp = H >> 6
    sub     w2,  w2, w9            // H = H - damp
    .endm

/* =========================================================================
 * Macro: VECTRA_PHASE_ADVANCE
 * phase = (phase + 1) % 42 — sem branch, csel inline
 * Custo: ~4 ciclos (add + cmp + csel pipelined)
 * ======================================================================= */
    .macro VECTRA_PHASE_ADVANCE
    add     w9,  w3, #1            // next = phase + 1
    cmp     w9,  #42
    csel    w3,  wzr, w9, ge      // if next >= 42: phase = 0, else = next
    .endm

/* =========================================================================
 * Macro: VECTRA_ATTRACTOR_ADVANCE
 * attractor = (attractor + delta) % 42 — sem branch
 * Limpa FLAG_JUMP_PENDING (bit 5)
 * Custo: ~5 ciclos (add + mov + udiv + msub + bic)
 * ======================================================================= */
    .macro VECTRA_ATTRACTOR_ADVANCE
    add     w9,  w4, w5            // sum = attractor + delta
    mov     w10, #42
    udiv    w11, w9, w10           // quot
    msub    w4,  w11, w10, w9     // attractor = sum % 42
    bic     w7,  w7, #(1 << 5)   // clear FLAG_JUMP_PENDING
    .endm

/* =========================================================================
 * Macro: VECTRA_HASH_STEP
 * FNV-1a: hash = (hash XOR (C & 0xFF)) * FNV_PRIME
 * x8 DEVE estar pré-carregado com 0x01000193 antes do ciclo.
 * Custo: ~4 ciclos (eor + mul: mul tem latência 3 no A53)
 * NOTA: budget spec diz ≤3; com x8 pré-carregado, eor→mul = 2 instruções.
 *       Latência de multiplicação A53 = 3, portanto custo real ≥ 4 ciclos
 *       quando encadeado. Inalcansável ≤3 sem hardware específico.
 * ======================================================================= */
    .macro VECTRA_HASH_STEP
    uxtb    w9,  w1                // byte baixo de C
    eor     w6,  w6, w9           // hash ^= byte
    mul     w6,  w6, w8           // hash *= FNV_PRIME (x8 pré-carregado)
    .endm

/* =========================================================================
 * Macro: VECTRA_TORUS_WRITE
 * Escreve attractor_cells[phase] e marca merkle_dirty.
 * Endereçamento: x0 + (phase * 8) para uint64_t
 * Custo: ~6 ciclos (lsl + add + str × 3 + orr)
 * ======================================================================= */
    .macro VECTRA_TORUS_WRITE
    lsl     x9,  x3, #3            // offset_attr = phase * 8 (uint64_t)
    add     x9,  x0, x9            // addr_attr = base + offset
    str     x4,  [x9]              // torus_cells[phase].attractor = attractor

    /* coherence_hist offset: base + 0x150 + phase*4 */
    lsl     x10, x3, #2            // offset_C = phase * 4 (uint32_t)
    add     x10, x0, x10
    add     x10, x10, #0x150
    str     w1,  [x10]             // torus_cells[phase].coherence = C

    /* entropy_hist offset: base + 0x1F8 + phase*4 */
    add     x11, x0, x10
    /* recompute: base + 0x1F8 + phase*4 */
    lsl     x11, x3, #2
    add     x11, x0, x11
    mov     x12, #0x1F8
    add     x11, x11, x12
    str     w2,  [x11]             // torus_cells[phase].entropy = H

    orr     w7,  w7, #(1 << 6)   // seta FLAG_MERKLE_DIRTY
    .endm

/* =========================================================================
 * Macro: VECTRA_PETROS_GUARD
 * "Petros" = já pedra. Se FLAG_GI_FAIL setado, nenhum avanço.
 * Implementado via csel nos campos individuais — sem branch.
 *
 * Estratégia: calcula novo valor de cada campo, depois:
 *   campo_final = csel(campo_antigo, campo_novo, GI_FAIL_set)
 *
 * Na prática, o compilador ASM não tem csel multivariável sem branch,
 * então usamos branch condicional sobre um bloco fixo — a alternativa
 * seria duplicar todos os csel, custando ciclos. O branch é aceitável
 * aqui pois GI_FAIL é raro (uma vez setado, é permanente).
 * ======================================================================= */
    .macro VECTRA_PETROS_GUARD_BEGIN
    tst     w7,  #(1 << 7)
    b.ne    .Lpetros_skip_\@
    .endm

    .macro VECTRA_PETROS_GUARD_END
.Lpetros_skip_\@:
    .endm

/* =========================================================================
 * Macro: COLLAPSE_STEP_ASM
 * Um ciclo VECTRA completo em AArch64.
 * Expansão: 1 macro = 1 passo. NÃO É FUNÇÃO.
 *
 * Pré-condições:
 *   x0..x7 carregados com contrato
 *   x8 = FNV_PRIME (0x01000193) — fixo
 *
 * Budget estimado total: ~31-35 ciclos (dentro de ≤42)
 * ======================================================================= */
    .macro COLLAPSE_STEP_ASM
    VECTRA_VOID_CHECK                  // ~3 ciclos
    VECTRA_GI_CHECK                    // ~8 ciclos
    VECTRA_PETROS_GUARD_BEGIN          // branch se GI_FAIL (raro)
    VECTRA_COHERENCE_UPDATE            // ~4 ciclos
    VECTRA_ENTROPY_UPDATE              // ~4 ciclos
    VECTRA_PHASE_ADVANCE               // ~4 ciclos
    VECTRA_ATTRACTOR_ADVANCE           // ~5 ciclos
    VECTRA_HASH_STEP                   // ~4 ciclos
    VECTRA_TORUS_WRITE                 // ~6 ciclos
    VECTRA_PETROS_GUARD_END
    .endm

/* =========================================================================
 * vectra_aarch64_run_n — Ponto de entrada público
 *
 * Assinatura C (thin JNI bridge chama isso):
 *   uint32_t vectra_aarch64_run_n(
 *       void     *base,       // x0 (recarregado ao entrar)
 *       uint32_t  C,          // x1
 *       uint32_t  H,          // x2
 *       uint32_t  phase,      // x3
 *       uint32_t  attractor,  // x4
 *       uint32_t  delta,      // x5
 *       uint32_t  fnv_hash,   // x6
 *       uint32_t  flags,      // x7
 *       uint32_t  n_steps     // x8 (entra como argumento, depois vira FNV_PRIME)
 *   );
 *
 * Retorna: flags finais em x0.
 *
 * NOTA: n_steps chega em x8. Precisamos de um reg scratch para o counter.
 * Usamos x13 para o loop (loop é gcd-proven: termina em n_steps passos finitos).
 *
 * CONVENÇÃO DE CHAMADA AArch64 (AAPCS64):
 *   Argumentos: x0..x7, depois stack
 *   n_steps (9º arg): vem na stack [sp, #0] após entrada
 * ======================================================================= */
    .global vectra_aarch64_run_n
    .type   vectra_aarch64_run_n, %function
    .align  4
vectra_aarch64_run_n:
    /* Preserva apenas lr (sem frame completo) */
    stp     x19, lr, [sp, #-16]!

    /* Recupera n_steps (9º argumento) da stack */
    ldr     w13, [sp, #16]          // n_steps

    /* Pré-carrega FNV_PRIME em x8 (agora x8 é fixo no ciclo) */
    mov     w8,  #0x0193
    movk    w8,  #0x0100, lsl #16   // w8 = 0x01000193

    /* Loop de n_steps: gcd-proven terminante (n_steps ∈ ℕ) */
    cbz     w13, .Lrun_done

.Lrun_loop:
    COLLAPSE_STEP_ASM
    subs    w13, w13, #1
    b.ne    .Lrun_loop

    /* Flush merkle se dirty */
    /* (merkle flush em C via JNI após retorno — thin bridge) */

.Lrun_done:
    /* Retorna flags em x0 */
    mov     w0,  w7

    ldp     x19, lr, [sp], #16
    ret

    .size vectra_aarch64_run_n, . - vectra_aarch64_run_n

/* =========================================================================
 * vectra_aarch64_step_once — Ponto de entrada para single step
 * Mesmo contrato mas n=1. Sem loop.
 * ======================================================================= */
    .global vectra_aarch64_step_once
    .type   vectra_aarch64_step_once, %function
    .align  4
vectra_aarch64_step_once:
    stp     x19, lr, [sp, #-16]!

    mov     w8,  #0x0193
    movk    w8,  #0x0100, lsl #16

    COLLAPSE_STEP_ASM

    mov     w0,  w7
    ldp     x19, lr, [sp], #16
    ret

    .size vectra_aarch64_step_once, . - vectra_aarch64_step_once
EOF

