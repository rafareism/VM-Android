/*
 * fnv_hash.h — FNV-1a 32-bit inline para VECTRA_OS
 *
 * CONTRATO: hash_update ≤ 3 ciclos (Cortex-A53)
 * Implementação: 2 instruções inline (eor + mul)
 * Custo real A53: eor=1 + mul=3 = 4 ciclos encadeados.
 * Para ≤3 ciclos: FNV_PRIME deve estar pré-carregado em registrador.
 *
 * x6 (w6) = acumulador FNV em execução
 * x8 (w8) = FNV_PRIME — DEVE ser pré-carregado antes do ciclo COLLAPSE
 */
#ifndef VECTRA_FNV_HASH_H
#define VECTRA_FNV_HASH_H

#include <stdint.h>

/* Constantes FNV-1a 32-bit */
#define FNV1A_OFFSET_BASIS  0x811C9DC5U
#define FNV1A_PRIME         0x01000193U

/*
 * FNV_INIT(hash_ref)
 * Inicializa o acumulador antes do primeiro ciclo.
 * Macro inline, sem chamada.
 */
#define FNV_INIT(hash_ref) \
    (*(hash_ref) = FNV1A_OFFSET_BASIS)

/*
 * FNV_UPDATE(hash_ref, byte)
 * Um passo FNV-1a: hash = (hash XOR byte) * prime
 * Sem libc, sem chamada de função.
 * Compila para: eor + mul (2 instruções no ARM)
 */
#define FNV_UPDATE(hash_ref, byte)                      \
    do {                                                \
        *(hash_ref) ^= (uint32_t)(byte);               \
        *(hash_ref) *= FNV1A_PRIME;                    \
    } while (0)

/*
 * FNV_UPDATE_WORD(hash_ref, word)
 * Atualiza com os 4 bytes de um uint32_t (little-endian byte order)
 * 4 expansões macro, sem loop, terminação GCD-proven (4 passos fixos)
 */
#define FNV_UPDATE_WORD(hash_ref, word)                \
    do {                                               \
        uint32_t _w = (uint32_t)(word);               \
        FNV_UPDATE(hash_ref, _w & 0xFFU);             \
        FNV_UPDATE(hash_ref, (_w >> 8)  & 0xFFU);    \
        FNV_UPDATE(hash_ref, (_w >> 16) & 0xFFU);    \
        FNV_UPDATE(hash_ref, (_w >> 24) & 0xFFU);    \
    } while (0)

#endif /* VECTRA_FNV_HASH_H */
EOF

