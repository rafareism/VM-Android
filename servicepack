# 8. vectra_arm32.S — Implementação ARM32 (Thumb-2 + NEON fallback)
# =============================================================================
cat > "$REPO/rmr/src/main/cpp/vectra_arm32.S" << 'EOF'
/*
 * vectra_arm32.S — Implementação ARM32 do contrato VECTRA_OS
 *
 * Alvo: armeabi-v7a, Thumb-2, sem libc, sem stack frames.
 * Mapa de registros (ARM32 — equivalente ao AArch64):
 *   r0  = state base ptr
 *   r1  = coerência C  (Q16.16)
 *   r2  = entropia H   (Q16.16)
 *   r3  = fase mod 42
 *   r4  = atrator 0..41
 *   r5  = delta Δr
 *   r6  = hash FNV
 *   r7  = flags
 *   r8  = FNV_PRIME (pré-carregado)
 *   r9..r12 = scratch de macro
 */

    .arch armv7-a
    .thumb
    .text
    .syntax unified

/* =========================================================================
 * Constantes
 * ======================================================================= */
    .section .rodata
    .align 2
.Larm32_fnv_prime:
    .word   0x01000193
.Larm32_fnv_offset:
    .word   0x811C9DC5
.Larm32_torus_r:
    .word   42
.Larm32_void_attractor:
    .word   22
.Larm32_gcd_mask_lo:
    .word   0xA2AA2822
.Larm32_gcd_mask_hi:
    .word   0x00000220

    .text

/* =========================================================================
 * Macro ARM32: VECTRA32_VOID_CHECK
 * Se bit 2 de r7: r4 = 22 (VOID), else r4 = r4.
 * csel ARM32 equivalente: IT NE + MOV.
 * ======================================================================= */
    .macro VECTRA32_VOID_CHECK
    tst     r7,  #(1 << 2)
    movne   r4,  #22
    .endm

/* =========================================================================
 * Macro ARM32: VECTRA32_GI_CHECK
 * gcd(r5, 42) via máscara de 64 bits.
 * ARM32: 64 bits em par de registros (r9:r10).
 * ======================================================================= */
    .macro VECTRA32_GI_CHECK
    /* Carrega máscara coprima */
    ldr     r9,  =0xA2AA2822       // low 32
    ldr     r10, =0x00000220       // high 32
    /* r5 mod 42 */
    mov     r11, #42
    udiv    r12, r5, r11
    mls     r12, r12, r11, r5     // r12 = r5 % 42
    /* Se r12 < 32: shift no low word */
    cmp     r12, #32
    blo     .Lgci_low_\@
    /* r12 >= 32: shift no high word */
    sub     r12, r12, #32
    lsr     r9,  r10, r12
    b       .Lgci_test_\@
.Lgci_low_\@:
    lsr     r9,  r9,  r12
.Lgci_test_\@:
    tst     r9,  #1
    orrne   r7,  r7,  #0          /* coprimo: OK — NOP */
    orreq   r7,  r7,  #(1 << 7)  /* não coprimo: seta GI_FAIL */
    .endm

/* =========================================================================
 * Macro ARM32: VECTRA32_COHERENCE_UPDATE
 * C = C - (C >> 4) + (H >> 8)
 * ======================================================================= */
    .macro VECTRA32_COHERENCE_UPDATE
    lsr     r9,  r1, #4
    sub     r1,  r1, r9
    lsr     r9,  r2, #8
    add     r1,  r1, r9
    .endm

/* =========================================================================
 * Macro ARM32: VECTRA32_ENTROPY_UPDATE
 * H = H + (delta << 4) - (H >> 6)
 * ======================================================================= */
    .macro VECTRA32_ENTROPY_UPDATE
    lsl     r9,  r5, #4
    add     r2,  r2, r9
    lsr     r9,  r2, #6
    sub     r2,  r2, r9
    .endm

/* =========================================================================
 * Macro ARM32: VECTRA32_PHASE_ADVANCE
 * phase = (phase + 1) % 42
 * ======================================================================= */
    .macro VECTRA32_PHASE_ADVANCE
    add     r9,  r3, #1
    cmp     r9,  #42
    movge   r9,  #0
    mov     r3,  r9
    .endm

/* =========================================================================
 * Macro ARM32: VECTRA32_ATTRACTOR_ADVANCE
 * attractor = (attractor + delta) % 42
 * ======================================================================= */
    .macro VECTRA32_ATTRACTOR_ADVANCE
    add     r9,  r4, r5
    mov     r10, #42
    udiv    r11, r9, r10
    mls     r4,  r11, r10, r9
    bic     r7,  r7,  #(1 << 5)
    .endm

/* =========================================================================
 * Macro ARM32: VECTRA32_HASH_STEP
 * FNV-1a passo. r8 = FNV_PRIME pré-carregado.
 * ======================================================================= */
    .macro VECTRA32_HASH_STEP
    uxtb    r9,  r1
    eor     r6,  r6, r9
    mul     r6,  r6, r8
    .endm

/* =========================================================================
 * Macro ARM32: VECTRA32_TORUS_WRITE
 * Escreve torus_cells. Offsets idênticos ao AArch64.
 * ======================================================================= */
    .macro VECTRA32_TORUS_WRITE
    /* attractor_cells[phase] — offset 0x000, uint64_t → 8 bytes */
    lsl     r9,  r3, #3
    add     r9,  r0, r9
    str     r4,  [r9]              // low 32 do uint64_t
    mov     r10, #0
    str     r10, [r9, #4]         // high 32 = 0 (ARM32 não tem 64-bit store nativamente)
    /* coherence_hist[phase] — offset 0x150 */
    lsl     r9,  r3, #2
    add     r9,  r0, r9
    add     r9,  r9, #0x150
    str     r1,  [r9]
    /* entropy_hist[phase] — offset 0x1F8 */
    lsl     r9,  r3, #2
    add     r9,  r0, r9
    /* 0x1F8 = 0x100 + 0xF8 = 0x100 + 0xF8 */
    add     r9,  r9, #0x100
    add     r9,  r9, #0xF8
    str     r2,  [r9]
    orr     r7,  r7,  #(1 << 6)  // seta merkle_dirty
    .endm

/* =========================================================================
 * Macro ARM32: COLLAPSE_STEP_ARM32
 * Um ciclo VECTRA em ARM32 Thumb-2.
 * ======================================================================= */
    .macro COLLAPSE_STEP_ARM32
    VECTRA32_VOID_CHECK
    VECTRA32_GI_CHECK
    tst     r7,  #(1 << 7)         // petros guard
    bne     .Lpetros32_\@
    VECTRA32_COHERENCE_UPDATE
    VECTRA32_ENTROPY_UPDATE
    VECTRA32_PHASE_ADVANCE
    VECTRA32_ATTRACTOR_ADVANCE
    VECTRA32_HASH_STEP
    VECTRA32_TORUS_WRITE
.Lpetros32_\@:
    .endm

/* =========================================================================
 * Ponto de entrada: vectra_arm32_run_n
 * ======================================================================= */
    .global vectra_arm32_run_n
    .thumb_func
    .type   vectra_arm32_run_n, %function
    .align  2
vectra_arm32_run_n:
    push    {r4-r12, lr}

    /* Salva args extras: n_steps está na stack após push */
    ldr     r12, [sp, #40]         // 10 regs × 4 = 40 bytes de push

    /* Pré-carrega FNV_PRIME em r8 */
    ldr     r8,  =0x01000193

    cbz     r12, .Larm32_done

.Larm32_loop:
    COLLAPSE_STEP_ARM32
    subs    r12, r12, #1
    bne     .Larm32_loop

.Larm32_done:
    mov     r0,  r7                // retorna flags
    pop     {r4-r12, pc}

    .size vectra_arm32_run_n, . - vectra_arm32_run_n
EOF

# =============================================================================
# 9. vectra_jni.c — JNI thin bridge (ZERO abstrações de alto nível)
# =============================================================================
cat > "$REPO/rmr/src/main/cpp/vectra_jni.c" << 'EOF'
/*
 * vectra_jni.c — JNI thin bridge para VECTRA_OS
 *
 * CONTRATO:
 *   - JNI como única ponte entre JVM e código nativo
 *   - Sem malloc dentro do bridge
 *   - Re-materializa registros x0..x7 a partir de ByteBuffer direto
 *   - Despacha para AArch64 ASM → ARM32 ASM → C fallback
 *   - Sem exceções Java no hot path
 *
 * O ByteBuffer Java DEVE ter:
 *   - capacity >= TORUS_STATE_SIZE (1024 bytes)
 *   - alignment >= 8 bytes (use ByteBuffer.allocateDirect)
 */

#include <jni.h>
#include <stdint.h>
#include "vectra_os.h"

/* Declarações externas — implementadas em ASM ou C fallback */
#if defined(__aarch64__)
extern uint32_t vectra_aarch64_run_n(
    void *base, uint32_t C, uint32_t H,
    uint32_t phase, uint32_t attractor, uint32_t delta,
    uint32_t fnv_hash, uint32_t flags, uint32_t n_steps);
extern uint32_t vectra_aarch64_step_once(
    void *base, uint32_t C, uint32_t H,
    uint32_t phase, uint32_t attractor, uint32_t delta,
    uint32_t fnv_hash, uint32_t flags);
#elif defined(__arm__)
extern uint32_t vectra_arm32_run_n(
    void *base, uint32_t C, uint32_t H,
    uint32_t phase, uint32_t attractor, uint32_t delta,
    uint32_t fnv_hash, uint32_t flags, uint32_t n_steps);
#endif

extern int      vectra_fallback_init(uint32_t delta);
extern uint32_t vectra_fallback_step(void);
extern void     vectra_fallback_step_n(uint32_t n);
extern void     vectra_fallback_flush_merkle(void);
extern void     vectra_fallback_get_state(VectraState *dst);
extern uint32_t vectra_fallback_get_root_hash(void);

/*
 * Decodifica o VectraState de um int[8] Java que espelha x0..x7.
 * Layout do array Java:
 *   [0] = C (coerência Q16.16)
 *   [1] = H (entropia Q16.16)
 *   [2] = phase
 *   [3] = attractor
 *   [4] = delta
 *   [5] = fnv_hash
 *   [6] = flags
 *   [7] = reservado/version
 */
#define JNI_CLASS "com/termux/rafacodephi/rmr/VectraEngine"

/*
 * vectra_step_once: executa um COLLAPSE_STEP com o ByteBuffer como base.
 * Retorna: flags (x7) após o passo.
 */
JNIEXPORT jint JNICALL
Java_com_termux_rafacodephi_rmr_VectraEngine_nativeStepOnce(
    JNIEnv *env, jclass clazz,
    jobject state_buf,   /* ByteBuffer direto → base ptr (x0) */
    jintArray regs_arr   /* int[8]: C,H,phase,attractor,delta,hash,flags,_ */
) {
    (void)clazz;

    /* Obtém ponteiro direto ao buffer — sem cópia, sem malloc */
    void *base = (*env)->GetDirectBufferAddress(env, state_buf);
    if (!base) return (jint)FLAG_GI_FAIL; /* sinaliza erro via flags */

    /* Obtém os elementos do array sem cópia (GetPrimitiveArrayCritical) */
    jboolean is_copy = JNI_FALSE;
    jint *regs = (jint *)(*env)->GetPrimitiveArrayCritical(env, regs_arr, &is_copy);
    if (!regs) return (jint)FLAG_GI_FAIL;

    uint32_t C         = (uint32_t)regs[0];
    uint32_t H         = (uint32_t)regs[1];
    uint32_t phase     = (uint32_t)regs[2];
    uint32_t attractor = (uint32_t)regs[3];
    uint32_t delta     = (uint32_t)regs[4];
    uint32_t fnv_hash  = (uint32_t)regs[5];
    uint32_t flags     = (uint32_t)regs[6];

    uint32_t new_flags;

#if defined(__aarch64__)
    new_flags = vectra_aarch64_step_once(
        base, C, H, phase, attractor, delta, fnv_hash, flags);
#elif defined(__arm__)
    new_flags = vectra_arm32_run_n(
        base, C, H, phase, attractor, delta, fnv_hash, flags, 1);
#else
    /* C fallback — sincroniza estado via static */
    VectraState tmp;
    tmp.base      = base;
    tmp.C         = C;
    tmp.H         = H;
    tmp.phase     = phase;
    tmp.attractor = attractor;
    tmp.delta     = delta;
    tmp.fnv_hash  = fnv_hash;
    tmp.flags     = flags;
    COLLAPSE_STEP(&tmp);
    /* Relê estado atualizado do buffer para devolver */
    regs[0] = (jint)tmp.C;
    regs[1] = (jint)tmp.H;
    regs[2] = (jint)tmp.phase;
    regs[3] = (jint)tmp.attractor;
    regs[4] = (jint)tmp.delta;
    regs[5] = (jint)tmp.fnv_hash;
    regs[6] = (jint)tmp.flags;
    new_flags = tmp.flags;
#endif

    (*env)->ReleasePrimitiveArrayCritical(env, regs_arr, regs, 0);
    return (jint)new_flags;
}

/*
 * vectra_run_n: executa N COLLAPSE_STEPs.
 * Retorna: flags após todos os passos.
 */
JNIEXPORT jint JNICALL
Java_com_termux_rafacodephi_rmr_VectraEngine_nativeRunN(
    JNIEnv *env, jclass clazz,
    jobject state_buf,
    jintArray regs_arr,
    jint n_steps
) {
    (void)clazz;
    if (n_steps <= 0) return 0;

    void *base = (*env)->GetDirectBufferAddress(env, state_buf);
    if (!base) return (jint)FLAG_GI_FAIL;

    jboolean is_copy = JNI_FALSE;
    jint *regs = (jint *)(*env)->GetPrimitiveArrayCritical(env, regs_arr, &is_copy);
    if (!regs) return (jint)FLAG_GI_FAIL;

    uint32_t C         = (uint32_t)regs[0];
    uint32_t H         = (uint32_t)regs[1];
    uint32_t phase     = (uint32_t)regs[2];
    uint32_t attractor = (uint32_t)regs[3];
    uint32_t delta     = (uint32_t)regs[4];
    uint32_t fnv_hash  = (uint32_t)regs[5];
    uint32_t flags     = (uint32_t)regs[6];

    uint32_t new_flags;

#if defined(__aarch64__)
    new_flags = vectra_aarch64_run_n(
        base, C, H, phase, attractor, delta, fnv_hash, flags,
        (uint32_t)n_steps);
#elif defined(__arm__)
    new_flags = vectra_arm32_run_n(
        base, C, H, phase, attractor, delta, fnv_hash, flags,
        (uint32_t)n_steps);
#else
    vectra_fallback_step_n((uint32_t)n_steps);
    VectraState tmp_out;
    vectra_fallback_get_state(&tmp_out);
    regs[0] = (jint)tmp_out.C;
    regs[1] = (jint)tmp_out.H;
    regs[2] = (jint)tmp_out.phase;
    regs[3] = (jint)tmp_out.attractor;
    regs[4] = (jint)tmp_out.delta;
    regs[5] = (jint)tmp_out.fnv_hash;
    regs[6] = (jint)tmp_out.flags;
    new_flags = tmp_out.flags;
#endif

    (*env)->ReleasePrimitiveArrayCritical(env, regs_arr, regs, 0);
    return (jint)new_flags;
}

/*
 * vectra_get_root_hash: retorna hash Merkle raiz atual.
 */
JNIEXPORT jint JNICALL
Java_com_termux_rafacodephi_rmr_VectraEngine_nativeGetRootHash(
    JNIEnv *env, jclass clazz,
    jobject state_buf
) {
    (void)clazz;
    void *base = (*env)->GetDirectBufferAddress(env, state_buf);
    if (!base) return 0;
    return (jint)TORUS_MERKLE(base, 84);
}

/*
 * vectra_init: inicializa o buffer de estado do lado nativo.
 * Preenche os 1024 bytes com o estado inicial.
 * Retorna 0 = OK, -1 = delta inválido (GI_FAIL).
 */
JNIEXPORT jint JNICALL
Java_com_termux_rafacodephi_rmr_VectraEngine_nativeInit(
    JNIEnv *env, jclass clazz,
    jobject state_buf,
    jintArray regs_arr,
    jint delta_val
) {
    (void)clazz;
    void *base = (*env)->GetDirectBufferAddress(env, state_buf);
    if (!base) return -1;
    if ((*env)->GetDirectBufferCapacity(env, state_buf) < (jlong)TORUS_STATE_SIZE)
        return -1;

    /* Zera o buffer sem memset (sem libc) — loop de 128 uint64_t = 1024 bytes */
    volatile uint64_t *p = (volatile uint64_t *)base;
    uint32_t i;
    for (i = 0; i < (TORUS_STATE_SIZE / 8); i++) p[i] = 0ULL;

    jboolean is_copy = JNI_FALSE;
    jint *regs = (jint *)(*env)->GetPrimitiveArrayCritical(env, regs_arr, &is_copy);
    if (!regs) return -1;

    /* Inicializa estado */
    VectraState tmp;
    VECTRA_INIT(&tmp, base, (uint32_t)delta_val);

    regs[0] = (jint)tmp.C;
    regs[1] = (jint)tmp.H;
    regs[2] = (jint)tmp.phase;
    regs[3] = (jint)tmp.attractor;
    regs[4] = (jint)tmp.delta;
    regs[5] = (jint)tmp.fnv_hash;
    regs[6] = (jint)tmp.flags;
    regs[7] = (jint)0xVECTRA01; /* version tag */

    (*env)->ReleasePrimitiveArrayCritical(env, regs_arr, regs, 0);
    return (tmp.flags & FLAG_GI_FAIL) ? -1 : 0;
}
EOF

