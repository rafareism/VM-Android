    (*(crc_ref) = _crc32_table[((*(crc_ref)) ^ (uint8_t)(byte)) & 0xFFU] \
                  ^ ((*(crc_ref)) >> 8))

#define CRC32_INIT(crc_ref)   (*(crc_ref) = 0xFFFFFFFFU)
#define CRC32_FINAL(crc_ref)  (*(crc_ref) ^= 0xFFFFFFFFU)

/*
 * MERKLE_UPDATE(base, phase, value)
 * Escreve um nó folha da árvore Merkle e propaga hash para a raiz.
 * Árvore binária sobre 42 folhas: nós [42..84] = internos, nós [0..41] = folhas.
 * Sem malloc, sem libc. Sem loops (42 passos unrolled via macro iterativa).
 * 
 * Limitação de desempenho: propagação completa custo ~42 ops.
 * Para hot-path, use MERKLE_MARK_DIRTY e propague após o ciclo.
 */
#define MERKLE_SET_LEAF(base, leaf_idx, val)                                    \
    do {                                                                        \
        uint32_t _hash = FNV1A_OFFSET_BASIS;                                   \
        FNV_UPDATE_WORD(&_hash, (uint32_t)(val));                              \
        TORUS_MERKLE(base, (leaf_idx)) = _hash;                                \
    } while (0)

/*
 * MERKLE_PROPAGATE_ONE(base, child_idx)
 * Propaga um nó para seu pai. Sem loops.
 * pai = (child - 1) / 2 para árvore 0-indexed onde raiz=84
 */
#define MERKLE_PROPAGATE_ONE(base, child_idx)                                  \
    do {                                                                        \
        uint32_t _ci = (uint32_t)(child_idx);                                  \
        if (_ci > 0) {                                                         \
            uint32_t _pi  = (_ci - 1U) >> 1;                                  \
            uint32_t _sib = (_ci & 1U) ? _ci + 1U : _ci - 1U;                \
            uint32_t _h   = FNV1A_OFFSET_BASIS;                               \
            FNV_UPDATE_WORD(&_h, TORUS_MERKLE(base, _ci));                    \
            FNV_UPDATE_WORD(&_h, TORUS_MERKLE(base, _sib));                   \
            TORUS_MERKLE(base, _pi) = _h;                                     \
        }                                                                       \
    } while (0)

/*
 * MERKLE_COMMIT(base, phase, flags_ref)
 * Escreve folha Merkle, propaga raiz parcial, limpa merkle_dirty.
 * Sem libc. flags_ref aponta para espelho de x7.
 */
#define MERKLE_COMMIT(base, phase, val, flags_ref)                             \
    do {                                                                        \
        uint32_t _phase = (uint32_t)(phase) % TORUS_R;                        \
        MERKLE_SET_LEAF(base, _phase, val);                                    \
        MERKLE_PROPAGATE_ONE(base, _phase);                                    \
        TORUS_CRC32(base) = 0;                                                 \
        CRC32_INIT(&TORUS_CRC32(base));                                        \
        CRC32_UPDATE(&TORUS_CRC32(base), TORUS_MERKLE(base, 84));             \
        CRC32_FINAL(&TORUS_CRC32(base));                                       \
        TORUS_PHASE_STAMP(base)  = _phase;                                    \
        TORUS_FLAGS_MIRROR(base) = *(flags_ref);                              \
        *(flags_ref) &= ~FLAG_MERKLE_DIRTY;                                   \
    } while (0)

